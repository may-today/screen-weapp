    <view
      class="flex-shrink-0 flex items-center justify-center size-10 rounded-full"
      hover-class="bg-accent"
      bind:tap="handleCloseButtonTap"
    >
      <view class="i-lucide-x text-base" />
    </view>
    <connect-status bind:tap="handleConnectStatusTap" />
  </view>
</view>
