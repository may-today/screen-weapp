<view
  class="nav-outer border-b border-border bg-background"
  style="padding-top: {{statusBarHeight}}px; padding-right: {{innerPaddingRight}}px;"
>
  <view
    class="nav-inner flex flex-row items-center gap-1.5 px-2"
    style="height: {{navBarHeight}}px;"
  >
    <view
      class="shrink-0 flex items-center justify-center size-8 rounded-full"
      hover-class="bg-accent"
      bind:tap="handleCloseButtonTap"
    >
      <view class="i-lucide-x text-sm" />
    </view>
    <connect-status bind:tap="handleConnectStatusTap" />
  </view>
</view>
