<view
  id="{{detail.slug}}"
  class="flex flex-col items-stretch justify-center mx-2 px-2 py-1.5 rounded-md min-h-8 first:mt-1.5 last:mb-1.5 {{ active ? 'bg-primary text-primary-foreground' : '' }}"
  hover-class="bg-accent text-accent-foreground"
>
  <view class="flex flex-row items-center gap-1.5">
    <text class="text-sm flex-1 shrink-0">{{detail.title}}</text>
    <view
      wx:if="{{detail.meta && detail.meta.banlam}}"
      class="flex items-center justify-center size-5 rounded-sm bg-accent text-accent-foreground"
    >
      <text class="text-xs">闽</text>
    </view>
    <text
      wx:if="{{detail.meta && detail.meta.year}}"
      class="text-xs text-muted-foreground max-w-24"
    >{{detail.meta.year}}</text>
  </view>
  <text wx:if="{{extraInfo}}" class="text-xs text-muted-foreground leading-4">{{extraInfo}}</text>
</view>
