<view class="bg-card p-3 pr-4 rounded-xl border border-border flex flex-row items-center gap-3">
  <view class="flex-shrink-0 flex items-center justify-center size-14 p-2 rounded-md bg-neutral-100 dark:bg-neutral-700/30">
    <image src="../../assets/device-{{ parsedDeviceInfo.device }}.png" class="h-full w-full" mode="aspectFit" />
  </view>
  <view class="flex-1 flex flex-col gap-1.5 overflow-hidden">
    <text class="w-full font-medium" overflow="ellipsis">{{ device.name }}</text>
    <view class="flex flex-row items-center gap-1.5 text-sm">
      <signal-icon rssi="{{ device.RSSI }}" />
      <text class="text-muted-foreground text-xs">{{ parsedDeviceInfo.displayName }}</text>
    </view>
  </view>
  <button size="mini" bind:tap="handleClickConnectButton">
    连接
  </button>
</view>